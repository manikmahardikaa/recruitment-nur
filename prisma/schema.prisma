// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-1.1.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum RecruitmentStage {
  NEW_APPLICANT
  SCREENING
  INTERVIEW
  OFFERING
  HIRED
  REJECTED
  WAITING
}

enum QuestionEvaluastionType {
  TEXT
  NUMBER
  RATING
  BOOLEAN
  SINGLE_SELECT
  MULTI_SELECT
}

enum QuestionScreeningType {
  SINGLE_CHOICE
  MULTIPLE_CHOICE
  TEXT
}

enum LocationType {
  HEAD_OFFICE
  BRANCH_OFFICE
}

enum Role {
  SUPER_ADMIN
  ADMIN
  CANDIDATE
}

enum QuestionMatriksType {
  SINGLE_CHOICE
  TEXT
}

enum EvaluationStatus {
  PENDING
  SUBMITTED
}

enum OfferDecisionStatus {
  PENDING
  ACCEPTED
  DECLINED
}

enum MessageType {
  TEXT
  IMAGE
  FILE
  SYSTEM
}

enum WorkType {
  ONSITE
  HYBRID
  REMOTE
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERNSHIP
  FREELANCE
}

enum TypeJob {
  TEAM_MEMBER
  REFFERAL
}

enum MethodEmployeeSetupQuestion {
  CHECK
  INPUT
  LINK
  UPLOAD
}

model Job {
  id                   String         @id @default(cuid())
  job_title            String
  job_role             String
  until_at             DateTime
  description          String         @db.LongText
  description_sections Json?
  requirement          Json?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  salary_min           Int
  salary_max           Int
  type_job             TypeJob        @default(TEAM_MEMBER)
  arrangement          WorkType
  commitment           EmploymentType
  is_have_domicile     Boolean        @default(false)
  is_draft             Boolean        @default(true)
  show_salary          Boolean        @default(false)
  is_published         Boolean        @default(false)
  step                 Int            @default(0)
  user_id              String?
  owner                User?          @relation("JobOwner", fields: [user_id], references: [id], onDelete: SetNull, onUpdate: Cascade)
  merchant_id          String?
  merchant             Merchant?      @relation(fields: [merchant_id], references: [id], onDelete: SetNull, onUpdate: Cascade)

  location_id   String?
  location      Location?      @relation(fields: [location_id], references: [id], onDelete: Cascade, onUpdate: Cascade)
  candidate     User[]         @relation("CandidateJobs")
  Applicant     Applicant[]

  @@map("job")
}

model Location {
  id          String       @id @default(cuid())
  name        String
  maps_url    String
  type        LocationType @default(HEAD_OFFICE)
  address     String
  district    String
  province    String
  country     String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  user_id     String
  merchant_id String?

  user          User            @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: Cascade)
  merchant      Merchant?       @relation(fields: [merchant_id], references: [id], onDelete: SetNull, onUpdate: Cascade)
  job           Job[]

  @@map("location")
}

model User {
  id                   String    @id @default(cuid())
  email                String    @unique
  name                 String
  password             String
  role                 Role      @default(CANDIDATE)
  phone                String?
  curiculum_vitae_url  String?
  address              String?
  no_identity          String?
  no_identity_url      String?
  gender               String?
  date_of_birth        DateTime?
  photo_url            String?
  portfolio_url        String?
  no_unique            String?
  member_card_url      String?
  team_member_card_url String?

  job_id       String?
  job          Job?              @relation("CandidateJobs", fields: [job_id], references: [id], onDelete: Cascade, onUpdate: Cascade)
  location     Location[]
  jobsOwned    Job[]             @relation("JobOwner")

  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  Applicant           Applicant[]          @relation("UserApplicant")
  passwordResetTokens PasswordResetToken[]

  @@map("user")
}

model Merchant {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  jobs             Job[]
  locations        Location[]
  applicants       Applicant[]
  profileCompanies ProfileCompany[]

  @@map("merchant")
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  user_id   String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@map("password_reset_token")
}


model Applicant {
  id          String            @id @default(cuid())
  user_id     String
  user        User              @relation("UserApplicant", fields: [user_id], references: [id], onDelete: Cascade, onUpdate: Cascade)
  job_id      String
  job         Job               @relation(fields: [job_id], references: [id], onDelete: Cascade, onUpdate: Cascade)
  merchant_id String?
  merchant    Merchant?         @relation(fields: [merchant_id], references: [id], onDelete: SetNull, onUpdate: Cascade)
  stage       RecruitmentStage? @default(SCREENING)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  screeningSubmittedAt DateTime?

  historyCandidate HistoryCandidate[]

  @@map("applicant")
}


model HistoryCandidate {
  id           String           @id @default(cuid())
  applicant_id String
  applicant    Applicant        @relation(fields: [applicant_id], references: [id], onDelete: Cascade, onUpdate: Cascade)
  createdAt    DateTime         @default(now())
  stage        RecruitmentStage

  @@map("history_candidate")
}

model ProfileCompany {
  id           String   @id @default(cuid())
  company_name String
  merchant_id  String
  merchant     Merchant @relation(fields: [merchant_id], references: [id], onDelete: Cascade, onUpdate: Cascade)

  description   String   @db.LongText
  website_url   String?
  instagram_url String?
  facebook_url  String?
  linkedin_url  String?
  twitter_url   String?
  logo_url      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("profil_company")
}
